# ============================================================
# Root .gitignore — ai-demo monorepo
# ============================================================

# ─── macOS ───────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Icon?
ehthumbs.db
Thumbs.db

# ─── Editor / IDE ────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.editorconfig.local

# ─── Environment & Secrets ───────────────────────────────────
.env
.env.*
!.env.example
!.env.*.example
*.pem
*.key
*.cert
secrets/

# ─── Logs ────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Docker ──────────────────────────────────────────────────
docker-compose.override.yml

# ─── Misc ────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
.cache/

# ============================================================
# Python (agent/)
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/
pip-wheel-metadata/
*.whl

# Testing / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
nosetests.xml

# Type checking
.mypy_cache/
.dmypy.json
.pyre/
.pytype/

# Jupyter
.ipynb_checkpoints/

# ============================================================
# Node.js / Next.js (frontend/)
# ============================================================
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

.next/
out/
build/
coverage/

*.tsbuildinfo
next-env.d.ts
.vercel
.turbo/

# ============================================================
# Go (gateway/)
# ============================================================
# Compiled binaries
gateway/gateway
gateway/server
*.exe
*.exe~
*.dll
*.dylib
*.test
*.out

# Go workspace
go.work.sum

# Vendor directory (keep if vendoring, remove line if using modules only)
# vendor/

# ─── Data files (runtime) ────────────────────────────────────
*.db
*.db-journal
*.sqlite
*.sqlite3

# Vector database data
agent/data/chroma/
agent/data/milvus/
agent/data/elasticsearch/

# DeepDoc cache
cache/deepdoc/
.cache/

# ─── Screenshot tools ─────────────────────────────────────────
docs/screenshots/*.js
docs/screenshots/*.py
docs/screenshots/package*.json
docs/screenshots/node_modules/
