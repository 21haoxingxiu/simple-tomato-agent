################ LLM ################
OPENAI_API_KEY=sk-your-real-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_JUDGE_MODEL=gpt-4o-mini

################ Embeddings ################
EMBEDDING_PROVIDER=auto      # auto|openai|huggingface
EMBEDDING_MODEL=text-embedding-3-small

################ Vector Store ################
VECTOR_STORE=chroma          # chroma|milvus
CHROMA_DIR=./data/chroma
# MILVUS_URI=http://milvus:19530
# MILVUS_TOKEN=

################ BM25 / Elasticsearch ################
BM25_BACKEND=memory          # memory|elasticsearch
# ES_URL=http://elasticsearch:9200
# ES_INDEX_PREFIX=ai_demo_kb_

################ GraphRAG (Neo4j) ################
ENABLE_GRAPHRAG=false
# NEO4J_URI=bolt://neo4j:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=neo4j_pass

################ Reranker ################
RERANKER=rrf                 # rrf|cross_encoder
# RERANKER_MODEL=BAAI/bge-reranker-base

################ RAG ################
RAG_TOP_K=5
RAG_RECALL_K=12

################ DeepDoc / 文档增强解析 ################
# 是否启用 DeepDoc 增强解析（默认关闭，需要额外依赖）
ENABLE_DEEPDOC=false

# OCR 引擎选择 (paddleocr|tesseract|auto)
OCR_ENGINE=auto

# 解析级别 (basic|standard|enhanced)
# basic: 基础文本提取
# standard: 标准解析（默认）
# enhanced: 增强解析（OCR + 布局识别 + 表格结构识别）
DOCUMENT_PARSING_LEVEL=standard

# 是否启用 OCR（用于扫描件 PDF 和图片）
ENABLE_OCR=false

# 是否启用布局识别
ENABLE_LAYOUT_RECOGNITION=false

# 是否启用表格结构识别
ENABLE_TABLE_STRUCTURE_RECOGNITION=false

# DeepDoc 缓存目录（可选）
# DEEPDOC_CACHE_DIR=./cache/deepdoc

# HuggingFace 镜像（可选，用于下载模型）
# HF_ENDPOINT=https://hf-mirror.com

################ 语音 ################
STT_MODEL=whisper-1
TTS_MODEL=tts-1
TTS_VOICE=alloy

################ LangSmith ################
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__xxx
# LANGCHAIN_PROJECT=agentstudio

################ Database ################
# DATABASE_URL=postgresql+asyncpg://agent:agent123@postgres:5432/agentdb

################ Misc ################
ENV=development
LOG_LEVEL=INFO

################ 安全 / 暴露面收敛 ################
# 服务监听地址: 默认仅本地回环, 严禁 0.0.0.0.
# 容器场景由 docker-compose 内部用 HOST=0.0.0.0 + 宿主机 127.0.0.1:port 映射来收敛暴露面.
HOST=127.0.0.1
PORT=8000

# CORS 显式来源白名单 (逗号分隔, 严禁 "*")
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000

# IP + 端口白名单 (应用层): 跨主机调用必须在此显式声明授信网段, 支持单 IP / CIDR.
# 例如:  IP_ALLOWLIST=10.0.0.0/8,192.168.10.5
# 留空则仅放行本地回环 (127.0.0.0/8 + ::1).
IP_ALLOWLIST=

# 是否信任 X-Forwarded-For (仅在前置可信反代/网关时设为 true, 否则会被伪造头绕过白名单).
TRUST_PROXY=false
